@page "/clientes"
@inject HttpClient Http

<div class="container py-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="m-0">Clientes</h3>
        <div>
            <button class="btn btn-outline-primary me-2" @onclick="CargarClientes">Cargar clientes</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th class="d-none d-sm-table-cell">DNI</th>
                        <th class="d-none d-md-table-cell">Gmail</th>
                        <th class="d-none d-lg-table-cell">Teléfono</th>
                    </tr>
                </thead>
                <tbody>
                    @if (clientes != null && clientes.Count > 0)
                    {
                        @foreach (var c in clientes)
                        {
                            <tr>
                                <td>@c.ID</td>
                                <td>@c.Nombre</td>
                                <td>@c.Apellido</td>
                                <td class="d-none d-sm-table-cell">@c.DNI</td>
                                <td class="d-none d-md-table-cell">@c.Gmail</td>
                                <td class="d-none d-lg-table-cell">@c.Telefono</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6">No hay clientes</td></tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <hr />

    <h4>Crear cliente</h4>

    
    <EditForm Model="nuevoCliente" OnValidSubmit="CrearCliente" class="mb-5">

        <DataAnnotationsValidator />

        <ValidationSummary />

        <div class="row g-2">

            <div class="col-12 col-md-6">
                <label class="form-label">Nombre</label>
                <InputText class="form-control" @bind-Value="nuevoCliente.Nombre" placeholder="Nombre" />

                <ValidationMessage For="@(() => nuevoCliente.Nombre)" />
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label">Apellido</label>
                <InputText class="form-control" @bind-Value="nuevoCliente.Apellido" placeholder="Apellido" />

                <ValidationMessage For="@(() => nuevoCliente.Apellido)" />
            </div>

            <div class="col-12 col-sm-6 col-md-4">
                <label class="form-label">DNI</label>
                <InputText class="form-control" @bind-Value="nuevoCliente.DNI" placeholder="DNI" />

                <ValidationMessage For="@(() => nuevoCliente.DNI)" />
            </div>

            <div class="col-12 col-sm-6 col-md-4">
                <label class="form-label">Gmail</label>
                <InputText class="form-control" @bind-Value="nuevoCliente.Gmail" placeholder="Gmail" />

                <ValidationMessage For="@(() => nuevoCliente.Gmail)" />
            </div>

            <div class="col-12 col-sm-6 col-md-4">
                <label class="form-label">Teléfono</label>
                <InputText class="form-control" @bind-Value="nuevoCliente.Telefono" placeholder="Teléfono" />

                <ValidationMessage For="@(() => nuevoCliente.Telefono)" />
            </div>

        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Crear</button>

            <button type="button" class="btn btn-secondary"
                    @onclick="() => nuevoCliente = new CrearClienteDto()">
                Limpiar
            </button>
        </div>
    </EditForm>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger mt-3">@error</div>
    }
</div>

@code {
    private List<ClienteDto> clientes = new List<ClienteDto>();
    private bool cargando = false;
    private string? error;

    private CrearClienteDto nuevoCliente = new CrearClienteDto();

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        try
        {
            cargando = true;
            error = null;
            clientes = await Http.GetFromJsonAsync<List<ClienteDto>>("api/clientes") ?? new List<ClienteDto>();
        }
        catch (Exception ex)
        {
            error = "No se pudieron cargar los clientes: " + ex.Message;
            Console.WriteLine(ex);
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task CrearCliente()
    {
        try
        {
            error = null;

            var resp = await Http.PostAsJsonAsync("api/clientes", nuevoCliente);

            if (resp.IsSuccessStatusCode)
            {
                var creado = await resp.Content.ReadFromJsonAsync<ClienteDto>();

                if (creado != null)
                {
                    clientes.Add(creado);

                    nuevoCliente = new CrearClienteDto();
                }
            }
            else
            {
                var texto = await resp.Content.ReadAsStringAsync();
                error = $"Error al crear: {resp.StatusCode} - {texto}";
            }
        }
        catch (Exception ex)
        {
            error = "Excepción al crear cliente: " + ex.Message;
            Console.WriteLine(ex);
        }
    }
}