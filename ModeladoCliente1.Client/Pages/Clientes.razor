@page "/clientes"

@inject HttpClient Http

<PageTitle>Clientes</PageTitle>

<div class="clientes-container">

    <!-- ENCABEZADO -->

    <div class="header-panel">

        <div>
            <h1>👥 Panel de Clientes</h1>
            <p>Administración y registro de clientes del sistema</p>
        </div>

        <button class="btn-recargar"
                @onclick="CargarClientes">

            🔄 Recargar

        </button>

    </div>

    <!-- LOADING -->
    @if (cargando)
    {
        <div class="loading-box">

            <div class="spinner-border text-light"
                 role="status">

                <span class="visually-hidden">
                    Cargando...
                </span>

            </div>

            <p class="mt-3">
                Cargando clientes...
            </p>

        </div>
    }
    else
    {
        <!-- TABLA -->

        <div class="tabla-card">

            <h3 class="mb-4">
                📋 Lista de Clientes
            </h3>

            <div class="table-responsive">

                <table class="table tabla-clientes align-middle">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>DNI</th>
                            <th>Gmail</th>
                            <th>Teléfono</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (clientes != null && clientes.Count > 0)
                        {
                            @foreach (var c in clientes)
                            {
                                <tr>
                                    <td>@c.ID</td>
                                    <td>@c.Nombre</td>
                                    <td>@c.Apellido</td>
                                    <td>@c.DNI</td>
                                    <td>@c.Gmail</td>
                                    <td>@c.Telefono</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">
                                    No hay clientes registrados
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

    <!-- FORMULARIO -->

    <div class="form-card">

        <h3 class="mb-4">
            ➕ Crear Cliente
        </h3>

        <EditForm Model="nuevoCliente"
                  OnValidSubmit="CrearCliente">

            <DataAnnotationsValidator />

            <ValidationSummary />

            <div class="row g-3">

                <div class="col-md-6">

                    <label class="form-label">
                        Nombre
                    </label>

                    <InputText class="form-control input-custom"
                               @bind-Value="nuevoCliente.Nombre"
                               placeholder="Ingrese el nombre" />

                    <ValidationMessage For="@(() => nuevoCliente.Nombre)" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Apellido
                    </label>

                    <InputText class="form-control input-custom"
                               @bind-Value="nuevoCliente.Apellido"
                               placeholder="Ingrese el apellido" />

                    <ValidationMessage For="@(() => nuevoCliente.Apellido)" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        DNI
                    </label>

                    <InputText class="form-control input-custom"
                               @bind-Value="nuevoCliente.DNI"
                               placeholder="Ingrese DNI" />

                    <ValidationMessage For="@(() => nuevoCliente.DNI)" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Gmail
                    </label>

                    <InputText class="form-control input-custom"
                               @bind-Value="nuevoCliente.Gmail"
                               placeholder="Ingrese Gmail" />

                    <ValidationMessage For="@(() => nuevoCliente.Gmail)" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Teléfono
                    </label>

                    <InputText class="form-control input-custom"
                               @bind-Value="nuevoCliente.Telefono"
                               placeholder="Ingrese teléfono" />

                    <ValidationMessage For="@(() => nuevoCliente.Telefono)" />

                </div>

            </div>

            <div class="botones-formulario">

                <button type="submit"
                        class="btn-crear">

                    ✅ Crear Cliente

                </button>

                <button type="button"
                        class="btn-limpiar"
                        @onclick="() => nuevoCliente = new CrearClienteDto()">

                    🧹 Limpiar

                </button>

            </div>

        </EditForm>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mt-4">

                ⚠️ @error

            </div>
        }

    </div>

</div>

@code {

    private List<ClienteDto> clientes = new();

    private bool cargando = false;

    private string? error;

    private CrearClienteDto nuevoCliente = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        try
        {
            cargando = true;

            error = null;

            clientes =
                await Http.GetFromJsonAsync<List<ClienteDto>>("api/clientes")
                ?? new List<ClienteDto>();
        }
        catch (Exception ex)
        {
            error = "No se pudieron cargar los clientes";

            Console.WriteLine(ex);
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task CrearCliente()
    {
        try
        {
            error = null;

            var resp =
                await Http.PostAsJsonAsync("api/clientes", nuevoCliente);

            if (resp.IsSuccessStatusCode)
            {
                var creado =
                    await resp.Content.ReadFromJsonAsync<ClienteDto>();

                if (creado != null)
                {
                    clientes.Add(creado);

                    nuevoCliente = new CrearClienteDto();
                }
            }
            else
            {
                error = "No se pudo crear el cliente";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

}

<style>

    .clientes-container {
        min-height: 100vh;
        padding: 35px;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
    }

    .header-panel {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding: 25px;
        border-radius: 20px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(8px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.35);
    }

        .header-panel h1 {
            font-size: 38px;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .header-panel p {
            color: #cbd5e1;
            margin: 0;
            font-size: 16px;
        }

    .btn-recargar {
        background: #2563eb;
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-recargar:hover {
            background: #1d4ed8;
            transform: scale(1.03);
        }

    .tabla-card,
    .form-card {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 35px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.35);
    }

    .tabla-clientes {
        background-color: transparent !important;
        color: white !important;
        margin-bottom: 0;
    }

        .tabla-clientes thead,
        .tabla-clientes thead tr,
        .tabla-clientes thead th {
            background-color: #1e293b !important;
        }

            .tabla-clientes thead th {
                color: #f8fafc !important;
                border: none;
                padding: 18px;
                font-size: 15px;
                font-weight: bold;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .tabla-clientes tbody tr {
            background-color: rgba(255,255,255,0.03) !important;
            transition: 0.25s ease;
        }

            .tabla-clientes tbody tr:hover {
                background-color: rgba(37,99,235,0.25) !important;
            }

        .tabla-clientes td {
            color: #f1f5f9 !important;
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 16px;
            background-color: transparent !important;
        }

    .table-responsive {
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .input-custom {
        border-radius: 12px;
        border: none;
        padding: 12px;
        font-size: 15px;
    }

    .botones-formulario {
        margin-top: 25px;
        display: flex;
        gap: 15px;
    }

    .btn-crear,
    .btn-limpiar {
        border: none;
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-crear {
        background: #16a34a;
        color: white;
    }

        .btn-crear:hover {
            background: #15803d;
            transform: scale(1.03);
        }

    .btn-limpiar {
        background: #475569;
        color: white;
    }

        .btn-limpiar:hover {
            background: #334155;
            transform: scale(1.03);
        }

    .loading-box {
        text-align: center;
        padding: 60px;
    }

</style>